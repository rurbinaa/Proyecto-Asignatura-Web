@startuml Uniwell_Database_Model

!theme plain
top to bottom direction
skinparam linetype ortho

entity "User" as User {
    * ID : Pk
    --
    Code : String
    Name : String
    Email : String
    Role : String
    Shift : String
    Status : String
}

entity "Customer" as Customer {
    * ID : Pk
    --
    Name : String
}

entity "ProductionLine" as ProductionLine {
    * ID : Pk
    --
    Name : String
}

entity "PurchaseOrder" as PurchaseOrder {
    * ID : Pk
    --
    PO_Number : String
    Customer_Id : Fk
}

entity "Style" as Style {
    * ID : Pk
    --
    Name : String
    ArtCode : String
    Size : String
    Color : String
    Material : String
}

entity "DefectCategory" as DefectCategory {
    * ID : Pk
    --
    Name : String
}

entity "DefectType" as DefectType {
    * ID : Pk
    --
    Name : String
    DefectCategory_Id : Fk
}

entity "Inspection" as Inspection {
    * ID : Pk
    --
    Date : DateTime
    Week : Int
    BatchCode : String
    Inspector_Id : Fk
    PurchaseOrder_Id : Fk
    Style_Id : Fk
    ProductionLine_Id : Fk
    Quantity : Int
    SampleSize : Int
    Accepted : Int
    Rejected : Int
    Seconds : Int
    AQL_Percentage : Float
    FinalStatus : String
    TotalFixed : Int
    TotalDefinitive : Int
}

entity "InspectionDefect" as InspectionDefect {
    * ID : Pk
    --
    Inspection_Id : Fk
    DefectType_Id : Fk
    DefectCount : Int
    Coordinate_X : Float
    Coordinate_Y : Float
    Image : String
    Comment : String
}

entity "ContainerAudit" as ContainerAudit {
    * ID : Pk
    --
    Date : DateTime
    ContainerNumber : String
    TransferNumber : String
    Customer_Id : Fk
    TotalPalettes : Int
    PalettesPass : Int
    PalettesReject : Int
    PassPercentage : Float
    RejectPercentage : Float
}

entity "ContainerDefect" as ContainerDefect {
    * ID : Pk
    --
    ContainerAudit_Id : Fk
    DefectType_Id : Fk
    DefectCount : Int
}

' Relaciones
PurchaseOrder }o--|| Customer
Inspection }o--|| PurchaseOrder
Inspection }o--|| Style
Inspection }o--|| ProductionLine
Inspection }o--|| User

DefectType }o--|| DefectCategory

InspectionDefect }o--|| Inspection
InspectionDefect }o--|| DefectType

ContainerAudit }o--|| Customer
ContainerDefect }o--|| ContainerAudit
ContainerDefect }o--|| DefectType

@enduml